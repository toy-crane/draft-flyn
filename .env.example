# Supabase
# `URL` and `PUBLISHABLE_KEY` are sent to the browser (NEXT_PUBLIC_ prefix).
# `SECRET_KEY` is server-only — never expose it.
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Vercel AI Gateway — read automatically by the `ai` package's gateway provider.
AI_GATEWAY_API_KEY=vck_xxxxxxxxxxxxxxxxxxxxxxxx
